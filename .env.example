# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Model used for the agent loop. Haiku is the default for latency/cost;
# swap to a larger model (e.g. claude-sonnet-5) if you need stronger reasoning
# for more complex tool orchestration.
LLM_MODEL=claude-haiku-4-5-20251001

# Safety valve on the tool-calling loop — prevents infinite tool-call cycles.
MAX_TOOL_ITERATIONS=5

# SQLite file used for the notes tool (created automatically on first run).
DATABASE_PATH=./jarvis.db

# Static key required in the X-API-Key header on every /chat request.
# Pick any long random string -- e.g. generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=choose-a-long-random-secret-here
